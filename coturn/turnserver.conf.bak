# coturn TURN/STUN server configuration for pluma (self-hosted Telegram)
# Docs: https://github.com/coturn/coturn/wiki/turnserver

# Listening ports
listening-port=3478
tls-listening-port=5349

# Your server's public IP (required for NAT traversal)
# Replace with your actual VPS IP or domain
external-ip=YOUR_SERVER_IP

# Credentials (MUST match COTURN_USER / COTURN_PASS in .env)
lt-cred-mech
user=pluma:FCBarcelona2k!9100

# Realm (can be your domain)
realm=pluma.chat

# Logging
log-file=/var/log/coturn/turnserver.log
verbose

# Security: only relay traffic (don't act as open proxy)
no-multicast-peers
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=172.16.0.0-172.31.255.255

# Fingerprint in TURN messages
fingerprint

# Disable CLI (not needed in Docker)
no-cli
