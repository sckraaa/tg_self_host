# ---- Build stage ----
FROM node:22-alpine AS builder

WORKDIR /app

# Build tools needed to compile better-sqlite3 native addon
RUN apk add --no-cache python3 make g++

COPY package.json package-lock.json* ./
RUN npm ci

COPY tsconfig.json ./
COPY src/ ./src/
COPY data/ ./data/
# rsa_private.pem is generated by setup.sh before docker build
COPY rsa_private.pem ./rsa_private.pem

RUN npm run build

# ---- Runtime stage ----
FROM node:22-alpine AS runtime

WORKDIR /app

# Build tools needed to compile better-sqlite3 native addon in prod install
RUN apk add --no-cache python3 make g++

# Production deps only (scripts must run for better-sqlite3 to compile)
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

# Compiled JS + static data + RSA private key (server identity)
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/data ./data
COPY --from=builder /app/rsa_private.pem ./rsa_private.pem

# Persistent DB lives in a named volume mounted at /app/db
ENV DB_PATH=/app/db/telegram.db
ENV PORT=8080
ENV TCP_PORT=8443
ENV HOST=0.0.0.0

EXPOSE 8080
EXPOSE 8443

COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["node", "dist/index.js"]
