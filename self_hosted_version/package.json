{
  "name": "telegram-self-hosted",
  "version": "0.1.0",
  "description": "Self-hosted Telegram backend with MTProto 2.0 protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "capture:official": "node --import tsx scripts/capture_official_telegram.ts",
    "capture:summary": "node --import tsx scripts/extract_capture_summary.ts"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.6"
  }
}
