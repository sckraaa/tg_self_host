    case 0xa319e569: { // payments.getSavedStarGifts
      console.log(`[${new Date().toISOString()}] Session ${session.id} payments.getSavedStarGifts`);
      return buildSavedStarGiftsEmpty();
    }

    case 0xa5d0514d: { // payments.getStarGiftActiveAuctions
      console.log(`[${new Date().toISOString()}] Session ${session.id} payments.getStarGiftActiveAuctions`);
      return buildStarGiftActiveAuctionsEmpty();
    }

    case 0x5dd8c7b8: { // auth.initPasskeyLogin
      console.log(`[${new Date().toISOString()}] Session ${session.id} auth.initPasskeyLogin (unsupported)`);
      return buildRpcErrorObject(400, 'PASSKEY_NOT_SUPPORTED');
    }

    case 0xd5a5d3a1: { // messages.getStickers
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.getStickers`);
      // messages.stickersNotModified#f1749a22
      const sW = new BinaryWriter();
      sW.writeInt(0xf1749a22);
      return sW.getBytes();
    }

    // ========== PRIORITY 1: resolve, notify, pin ==========

    case 0x725afbbc: { // contacts.resolveUsername
      console.log(`[${new Date().toISOString()}] Session ${session.id} contacts.resolveUsername`);
      const reader = new BinaryReader(data);
      reader.offset = 4; // skip constructor
      const rFlags = reader.readInt();
      const username = readTlString(reader);
      console.log(`[${new Date().toISOString()}] resolveUsername: "${username}"`);
      return buildResolvedPeer(username);
    }

    case 0x8af94344: { // contacts.resolvePhone
      console.log(`[${new Date().toISOString()}] Session ${session.id} contacts.resolvePhone`);
      const reader = new BinaryReader(data);
      reader.offset = 4; // skip constructor
      const phone = readTlString(reader);
      console.log(`[${new Date().toISOString()}] resolvePhone: "${phone}"`);
      const user = messageStore.getUserByPhone(phone);
      if (!user) return buildRpcErrorObject(400, 'PHONE_NOT_OCCUPIED');
      return buildResolvedPeerForUser(user);
    }

    case 0x84be5b93: { // account.updateNotifySettings
      console.log(`[${new Date().toISOString()}] Session ${session.id} account.updateNotifySettings`);
      return buildBoolTrue();
    }

    case 0xa731e257: { // messages.toggleDialogPin
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.toggleDialogPin`);
      return buildBoolTrue();
    }

    case 0x3b1adf37: { // messages.reorderPinnedDialogs
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.reorderPinnedDialogs`);
      return buildBoolTrue();
    }

    // ========== PRIORITY 2: upload, media, avatar ==========

    case 0xb304a621: { // upload.saveFilePart
      console.log(`[${new Date().toISOString()}] Session ${session.id} upload.saveFilePart`);
      const reader = new BinaryReader(data);
      reader.offset = 4;
      const fileId = reader.readLong();
      const filePart = reader.readInt();
      const bytesLen = reader.readInt();
      const bytes = data.slice(reader.offset, reader.offset + bytesLen);
      messageStore.saveFilePart(fileId.toString(), filePart, bytes);
      return buildBoolTrue();
    }

    case 0xde7b673d: { // upload.saveBigFilePart
      console.log(`[${new Date().toISOString()}] Session ${session.id} upload.saveBigFilePart`);
      const reader = new BinaryReader(data);
      reader.offset = 4;
      const fileId = reader.readLong();
      const filePart = reader.readInt();
      const fileTotalParts = reader.readInt();
      const bytesLen = reader.readInt();
      const bytes = data.slice(reader.offset, reader.offset + bytesLen);
      messageStore.saveFilePart(fileId.toString(), filePart, bytes);
      return buildBoolTrue();
    }

    case 0xbe5335be: { // upload.getFile
      console.log(`[${new Date().toISOString()}] Session ${session.id} upload.getFile`);
      const reader = new BinaryReader(data);
      reader.offset = 4;
      const getFileFlags = reader.readInt();
      const locationConstructor = reader.readInt();
      // inputPhotoFileLocation#40181ffe = volumeId + localId + secret
      // inputDocumentFileLocation#bad07584 = id + access_hash + file_reference
      // inputPeerPhotoFileLocation#37c1011c = flags + peer + photo_id
      let fileData: Buffer | undefined;
      if (locationConstructor === 0x37c1011c) {
        // inputPeerPhotoFileLocation — profile photo
        const photoFlags = reader.readInt();
        skipInputPeer(reader);
        const photoId = reader.readLong();
        fileData = messageStore.getUploadedFile(photoId.toString());
      } else if (locationConstructor === 0xbad07584) {
        // inputDocumentFileLocation
        const docId = reader.readLong();
        fileData = messageStore.getUploadedFile(docId.toString());
      }
      if (!fileData) {
        // Return empty file
        const w = new BinaryWriter();
        w.writeInt(0x96a18d5); // upload.file
        w.writeInt(0x007efe10); // storage.fileUnknown
        w.writeInt(0); // mtime
        writeTlBytes(w, Buffer.alloc(0));
        return w.getBytes();
      }
      const w = new BinaryWriter();
      w.writeInt(0x96a18d5); // upload.file
      w.writeInt(0x40bc6f52); // storage.fileJpeg
      w.writeInt(Math.floor(Date.now() / 1000));
      writeTlBytes(w, fileData);
      return w.getBytes();
    }

    case 0x330e77f: { // messages.sendMedia
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.sendMedia`);
      // For now, treat like a text message with media placeholder
      const reader = new BinaryReader(data);
      reader.offset = 4;
      const sendMediaFlags = reader.readInt();
      // skip flags booleans, read peer
      const peerKey = readInputPeerKey(reader);
      // Skip reply_to if present (flag 0)
      if (sendMediaFlags & (1 << 0)) skipInputReplyTo(reader);
      // Skip media (complex — for now just store a text message)
      // Read message text after media
      const selfId = session.userId || SEED_USER_ID;
      // For simplicity, store as text message indicating media was sent
      const mediaText = '[Media message]';
      if (!peerKey) return buildRpcErrorObject(400, 'PEER_ID_INVALID');
      const isSavedMessages = peerKey === `user:${selfId}`;
      const isP2P = peerKey.startsWith('user:') && !isSavedMessages;
      const senderPeerKey = peerKey.startsWith('channel:') ? undefined : `user:${selfId}`;
      // Read random_id — skip to it: after media and message string, there's random_id
      // Since parsing media is complex, we just return an updates envelope with empty message
      return buildRpcErrorObject(400, 'MEDIA_INVALID');
    }

    case 0x388a3b5: { // photos.uploadProfilePhoto
      console.log(`[${new Date().toISOString()}] Session ${session.id} photos.uploadProfilePhoto`);
      // Stub: return empty photo
      const w = new BinaryWriter();
      // photos.photo#20212ca8 photo:Photo users:Vector<User>
      w.writeInt(0x20212ca8);
      // photoEmpty#2331b22d id:long
      w.writeInt(0x2331b22d);
      w.writeLong(BigInt(Date.now()));
      // users: empty vector
      writeEmptyVectorToWriter(w);
      return w.getBytes();
    }

    // ========== PRIORITY 3: forward, profile, reactions ==========

    case 0x78515775: { // account.updateProfile
      console.log(`[${new Date().toISOString()}] Session ${session.id} account.updateProfile`);
      const reader = new BinaryReader(data);
      reader.offset = 4;
      const profileFlags = reader.readInt();
      let newFirstName: string | undefined;
      let newLastName: string | undefined;
      let newAbout: string | undefined;
      if (profileFlags & (1 << 0)) newFirstName = readTlString(reader);
      if (profileFlags & (1 << 1)) newLastName = readTlString(reader);
      if (profileFlags & (1 << 2)) newAbout = readTlString(reader);

      const selfId = session.userId || SEED_USER_ID;
      if (newFirstName !== undefined || newLastName !== undefined) {
        messageStore.updateUser(selfId, {
          firstName: newFirstName,
          lastName: newLastName,
        });
      }

      const updatedUser = getFixtureUserForId(undefined, String(selfId), true);
      const w = new BinaryWriter();
      writeUserFromFixture(w, { ...updatedUser, self: true });
      return w.getBytes();
    }

    case 0x13704a7c: { // messages.forwardMessages
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.forwardMessages`);
      const selfId = session.userId || SEED_USER_ID;
      const fwdReq = parseForwardMessagesRequest(data, session);
      if (!fwdReq || !fwdReq.toPeerKey) {
        return buildRpcErrorObject(400, 'PEER_ID_INVALID');
      }

      const allUpdates: Buffer[] = [];
      const userIds: string[] = [String(selfId)];
      const chatIds: string[] = [];
      collectEntityIdsFromPeerKey(fwdReq.toPeerKey, userIds, chatIds);

      for (let i = 0; i < fwdReq.messageIds.length; i++) {
        // Get original message text
        const origMsg = messageStore.getMessageForUser(fwdReq.messageIds[i], selfId);
        const text = origMsg?.text || '';

        // Store forwarded message as sender's copy
        const stored = messageStore.appendOutgoingMessage(selfId, {
          peerKey: fwdReq.toPeerKey,
          text,
          clientRandomId: fwdReq.randomIds[i] || `fwd_${Date.now()}_${i}`,
          seedMaxMessageId: 0,
          fromPeerKey: `user:${selfId}`,
          post: false,
        });

        const fixture = getStoredMessageAsFixture(fwdReq.toPeerKey, stored.messageId, selfId);
        if (fixture) {
          allUpdates.push(buildUpdateNewMessage(fixture, stored.updatePts, stored.updatePtsCount));
        }

        // P2P: store incoming copy for recipient
        const isSavedMessages = fwdReq.toPeerKey === `user:${selfId}`;
        const isP2P = fwdReq.toPeerKey.startsWith('user:') && !isSavedMessages;
        if (isP2P) {
          const recipientId = Number(fwdReq.toPeerKey.replace('user:', ''));
          const recipientPeerKey = `user:${selfId}`;
          const recipientMsg = messageStore.appendOutgoingMessage(recipientId, {
            peerKey: recipientPeerKey,
            text,
            clientRandomId: `recv_fwd_${Date.now()}_${i}`,
            seedMaxMessageId: 0,
            fromPeerKey: `user:${selfId}`,
            post: false,
          });
          messageStore.markMessageIncoming(recipientId, recipientPeerKey, recipientMsg.messageId);
          const recipientFixture = getStoredMessageAsFixture(recipientPeerKey, recipientMsg.messageId, recipientId);
          if (recipientFixture) {
            broadcastToUser(recipientId, buildLiveUpdatesEnvelope(
              [buildUpdateNewMessage(recipientFixture, recipientMsg.updatePts, recipientMsg.updatePtsCount)],
              [String(selfId), String(recipientId)],
              [],
            ));
          }
        }
      }

      broadcastSessionUpdates(session, buildLiveUpdatesEnvelope(allUpdates, userIds, chatIds));
      return buildLiveUpdatesEnvelope(allUpdates, userIds, chatIds);
    }

    case 0xd30d78d4: { // messages.sendReaction
      console.log(`[${new Date().toISOString()}] Session ${session.id} messages.sendReaction`);
      return buildUpdatesEmpty();
    }

    default: {
      console.log(`[${new Date().toISOString()}] Session ${session.id} unhandled TL: 0x${constructorId.toString(16)}`);
      return buildRpcErrorObject(400, `METHOD_NOT_IMPLEMENTED_0x${constructorId.toString(16)}`);
    }
  }
}

function skipInitConnection(data: Buffer): Buffer | null {
  // initConnection#c1cd5ea9 {X:Type} flags:# api_id:int device_model:string 
  // system_version:string app_version:string system_lang_code:string 
  // lang_pack:string lang_code:string proxy:flags.0?InputClientProxy params:flags.1?JSONValue query:!X
  try {
    let offset = 4; // skip constructor
    const flags = data.readUInt32LE(offset); offset += 4;
    offset += 4; // api_id
    
    // Skip TL strings: device_model, system_version, app_version, system_lang_code, lang_pack, lang_code
    for (let i = 0; i < 6; i++) {
      offset = skipTlString(data, offset);
    }
    
    // proxy (flags.0)
    if (flags & 1) {
      // InputClientProxy: constructor(4) + address(TL string) + port(4)
      offset += 4;
      offset = skipTlString(data, offset);
      offset += 4;
    }
    
    // params (flags.1) - JSONValue
    if (flags & 2) {
      offset = skipJsonValue(data, offset);
    }
    
    return data.slice(offset);
  } catch (e) {
    console.log(`[${new Date().toISOString()}] Failed to parse initConnection:`, (e as Error).message);
    return null;
  }
}

function skipTlString(data: Buffer, offset: number): number {
  const firstByte = data[offset];
  let len: number;
  let headerLen: number;
  
  if (firstByte <= 253) {
    len = firstByte;
    headerLen = 1;
  } else {
    len = data[offset + 1] | (data[offset + 2] << 8) | (data[offset + 3] << 16);
    headerLen = 4;
  }
  
  const totalOccupied = headerLen + len;
  const padding = totalOccupied % 4 === 0 ? 0 : 4 - (totalOccupied % 4);
  return offset + totalOccupied + padding;
}

function skipJsonValue(data: Buffer, offset: number): number {
  const constructor = data.readUInt32LE(offset);
  offset += 4;
  
  switch (constructor) {
    case 0xc7345e6a: // jsonObject
    {
      const count = data.readInt32LE(offset); offset += 4;
      for (let i = 0; i < count; i++) {
        offset = skipTlString(data, offset); // key
        offset = skipJsonValue(data, offset); // value
      }
      return offset;
    }
    case 0xc0de1bd9: // jsonString
      return skipTlString(data, offset);
    case 0x2be0dfa4: // jsonNumber
      return offset + 8; // double
    case 0xc7345e6a: // jsonArray
    {
      const count = data.readInt32LE(offset); offset += 4;
      for (let i = 0; i < count; i++) {
        offset = skipJsonValue(data, offset);
      }
      return offset;
    }
    case 0xc3f11eb2: // jsonBool
      return offset + 4;
    case 0x3f6d7b68: // jsonNull
      return offset;
    default:
      return offset;
  }
}

function writeTlString(w: BinaryWriter, str: string): void {
  const buf = Buffer.from(str, 'utf-8');
  let header: Buffer;
  let headerLen: number;
  if (buf.length <= 253) {
    header = Buffer.alloc(1);
    header[0] = buf.length;
    headerLen = 1;
  } else {
    header = Buffer.alloc(4);
    header[0] = 254;
    header[1] = buf.length & 0xff;
    header[2] = (buf.length >> 8) & 0xff;
    header[3] = (buf.length >> 16) & 0xff;
    headerLen = 4;
  }
  const totalLen = headerLen + buf.length;
  const padLen = (4 - (totalLen % 4)) % 4;
  w.writeBytes(Buffer.concat([header, buf, Buffer.alloc(padLen)]));
}

function writeTlBytes(w: BinaryWriter, data: Buffer): void {
  let header: Buffer;
  let headerLen: number;
  if (data.length <= 253) {
    header = Buffer.alloc(1);
    header[0] = data.length;
    headerLen = 1;
  } else {
    header = Buffer.alloc(4);
    header[0] = 254;
    header[1] = data.length & 0xff;
    header[2] = (data.length >> 8) & 0xff;
    header[3] = (data.length >> 16) & 0xff;
    headerLen = 4;
  }
  const totalLen = headerLen + data.length;
  const padLen = (4 - (totalLen % 4)) % 4;
  w.writeBytes(Buffer.concat([header, data, Buffer.alloc(padLen)]));
}

type ParsedHistoryRequest = {
  peerKey: string;
  offsetId: number;
  limit: number;
};

type ParsedSendMessageRequest = {
  peerKey: string;
  message: string;
  randomId: string;
};

type ParsedReadHistoryRequest = {
  peerKey: string;
  maxId: number;
};

type ParsedUpdatesDifferenceRequest = {
  pts: number;
};

type ParsedChannelRef = {
  channelId: string;
};

type ParsedUserRef = {
  userId: string;
};

type ParsedPeerRef = {
  peerKey: string;
};

function parseHistoryRequest(data: Buffer): ParsedHistoryRequest | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const peerKey = readInputPeerKey(reader);
  if (!peerKey) {
    return undefined;
  }

  const offsetId = reader.readInt();
  reader.readInt(); // offset_date
  reader.readInt(); // add_offset
  const limit = reader.readInt();

  return {
    peerKey,
    offsetId,
    limit,
  };
}

function parseGetMessagesRequest(data: Buffer): number[] | undefined {
  // messages.getMessages#63c66506 id:Vector<InputMessage>
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const vectorConstructor = reader.readInt() >>> 0;
  if (vectorConstructor !== 0x1cb5c415) {
    return undefined;
  }

  const count = reader.readInt();
  const ids: number[] = [];
  for (let i = 0; i < count; i++) {
    const inputMsgConstructor = reader.readInt() >>> 0;
    if (inputMsgConstructor === 0xa676a322) {
      // inputMessageID#a676a322 id:int
      ids.push(reader.readInt());
    } else if (inputMsgConstructor === 0x86872538) {
      // inputMessagePinned — skip
    } else if (inputMsgConstructor === 0xbad88395) {
      // inputMessageReplyTo#bad88395 id:int
      reader.readInt(); // skip id
    } else if (inputMsgConstructor === 0xacfa1571) {
      // inputMessageCallbackQuery#acfa1571 id:int query_id:long
      reader.readInt(); // skip id
      reader.readLong(); // skip query_id
    }
  }
  return ids;
}

// Old parsePeerDialogsRequest removed — replaced by the one near buildPeerDialogsForPeers

interface ParsedSetTypingRequest {
  peerKey: string;
  actionConstructor: number;
}

function parseSetTypingRequest(data: Buffer): ParsedSetTypingRequest | undefined {
  try {
    const reader = new BinaryReader(data);
    reader.readInt(); // skip constructor
    const flags = reader.readInt();
    const peerKey = readInputPeerKey(reader);
    if (!peerKey) return undefined;
    // top_msg_id is flags.0
    if (flags & 1) reader.readInt();
    const actionConstructor = reader.readInt() >>> 0;
    return { peerKey, actionConstructor };
  } catch {
    return undefined;
  }
}

interface ParsedEditMessageRequest {
  peerKey: string;
  messageId: number;
  newText?: string;
}

function parseEditMessageRequest(data: Buffer): ParsedEditMessageRequest | undefined {
  try {
    const reader = new BinaryReader(data);
    reader.readInt(); // skip constructor
    const flags = reader.readInt();
    const peerKey = readInputPeerKey(reader);
    if (!peerKey) return undefined;
    const messageId = reader.readInt();
    const newText = (flags & (1 << 11)) ? readTlString(reader) : undefined;
    return { peerKey, messageId, newText };
  } catch {
    return undefined;
  }
}

interface ParsedDeleteMessagesRequest {
  revoke: boolean;
  messageIds: number[];
}

function parseDeleteMessagesRequest(data: Buffer): ParsedDeleteMessagesRequest | undefined {
  try {
    const reader = new BinaryReader(data);
    reader.readInt(); // skip constructor
    const flags = reader.readInt();
    const revoke = !!(flags & 1);
    const vectorId = reader.readInt() >>> 0;
    if (vectorId !== 0x1cb5c415) return undefined;
    const count = reader.readInt();
    const messageIds: number[] = [];
    for (let i = 0; i < count; i++) {
      messageIds.push(reader.readInt());
    }
    return { revoke, messageIds };
  } catch {
    return undefined;
  }
}

function parseReadHistoryRequest(data: Buffer): ParsedReadHistoryRequest | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const peerKey = readInputPeerKey(reader);
  if (!peerKey) {
    return undefined;
  }

  return {
    peerKey,
    maxId: reader.readInt(),
  };
}

function parseUpdatesDifferenceRequest(data: Buffer): ParsedUpdatesDifferenceRequest | undefined {
  const constructorId = data.readUInt32LE(0);
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  if (constructorId === 0x25d218ec) {
    return {
      pts: reader.readInt(),
    };
  }

  const flags = reader.readInt() >>> 0;
  const pts = reader.readInt();
  if (flags & (1 << 1)) {
    reader.readInt(); // pts_limit
  }
  if (flags & (1 << 0)) {
    reader.readInt(); // pts_total_limit
  }

  return { pts };
}

function parseChannelReadHistoryRequest(data: Buffer): ParsedReadHistoryRequest | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const constructorId = reader.readInt() >>> 0;
  if (constructorId !== 0x27bcbbfc) { // inputChannel
    return undefined;
  }

  const channelId = reader.readLong().toString();
  reader.readLong(); // access_hash

  return {
    peerKey: `channel:${channelId}`,
    maxId: reader.readInt(),
  };
}

function parseGetFullChannelRequest(data: Buffer): ParsedChannelRef | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const constructorId = reader.readInt() >>> 0;
  if (constructorId !== 0x27bcbbfc) { // inputChannel
    return undefined;
  }

  return {
    channelId: reader.readLong().toString(),
  };
}

function parseGetFullUserRequest(data: Buffer, session?: ClientSession): ParsedUserRef | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  return readInputUserRef(reader, session);
}

function parseGetUsersRequest(data: Buffer, session?: ClientSession): ParsedUserRef[] | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const vectorConstructor = reader.readInt() >>> 0;
  if (vectorConstructor !== 0x1cb5c415) {
    return undefined;
  }

  const count = reader.readInt();
  const users: ParsedUserRef[] = [];
  for (let index = 0; index < count; index++) {
    const user = readInputUserRef(reader, session);
    if (user) {
      users.push(user);
    }
  }

  return users;
}

function parsePeerVectorRequest(data: Buffer): ParsedPeerRef[] | undefined {
  const reader = new BinaryReader(data);
  reader.offset = 4; // skip constructor
  const vectorConstructor = reader.readInt() >>> 0;
  if (vectorConstructor !== 0x1cb5c415) {
    return undefined;
  }

  const count = reader.readInt();
  const peers: ParsedPeerRef[] = [];
  for (let index = 0; index < count; index++) {
    const peerKey = readInputPeerKey(reader);
    if (peerKey) {
      peers.push({ peerKey });
    }
  }

  return peers;
}

function parseSendMessageRequest(data: Buffer): ParsedSendMessageRequest | undefined {
  try {
    const reader = new BinaryReader(data);
    reader.offset = 4; // skip constructor
    const flags = reader.readInt() >>> 0;

    const peerKey = readInputPeerKey(reader);
    if (!peerKey) {
      return undefined;
    }

    // Skip reply_to:flags.0?InputReplyTo if present
    if ((flags & (1 << 0)) !== 0) {
      if (!skipInputReplyTo(reader)) {
        console.log(`[WARN] parseSendMessageRequest: could not skip InputReplyTo`);
        return undefined;
      }
    }

    const message = readTlString(reader);
    const randomId = reader.readLong(false).toString();

    return {
      peerKey,
      message,
      randomId,
    };
  } catch (e) {
    console.log(`[WARN] parseSendMessageRequest: parse error:`, (e as Error).message);
    return undefined;
  }
}

function skipInputReplyTo(reader: BinaryReader): boolean {
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    case 0x869fbe10: { // inputReplyToMessage
      const flags = reader.readInt() >>> 0;
      reader.readInt(); // reply_to_msg_id
      if (flags & (1 << 0)) reader.readInt(); // top_msg_id
      if (flags & (1 << 1)) skipInputPeer(reader); // reply_to_peer_id
      if (flags & (1 << 2)) skipTlStringByReader(reader); // quote_text
      if (flags & (1 << 3)) skipTlVector(reader); // quote_entities
      if (flags & (1 << 4)) reader.readInt(); // quote_offset
      if (flags & (1 << 5)) skipInputPeer(reader); // monoforum_peer_id
      if (flags & (1 << 6)) reader.readInt(); // todo_item_id
      return true;
    }
    case 0x5881323a: { // inputReplyToStory
      skipInputPeer(reader); // peer
      reader.readInt(); // story_id
      return true;
    }
    case 0x69d66c45: { // inputReplyToMonoForum
      skipInputPeer(reader); // monoforum_peer_id
      return true;
    }
    default:
      return false;
  }
}

function skipInputPeer(reader: BinaryReader): void {
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    case 0xdde8a54c: // inputPeerUser
      reader.readLong(); // user_id
      reader.readLong(); // access_hash
      break;
    case 0x35a95cb9: // inputPeerChat
      reader.readLong(); // chat_id
      break;
    case 0x27bcbbfc: // inputPeerChannel
      reader.readLong(); // channel_id
      reader.readLong(); // access_hash
      break;
    case 0x7da07ec9: // inputPeerSelf
    case 0x7f3b18ea: // inputPeerEmpty
      break;
    default:
      throw new Error(`Unknown InputPeer constructor: 0x${constructorId.toString(16)}`);
  }
}

function skipTlStringByReader(reader: BinaryReader): void {
  const first = reader.readByte();
  let length = first;
  if (first === 254) {
    const bytes = reader.readBytes(3);
    length = bytes[0] | (bytes[1] << 8) | (bytes[2] << 16);
  }
  reader.readBytes(length);
  const headerLength = first === 254 ? 4 : 1;
  const padding = (4 - ((headerLength + length) % 4)) % 4;
  if (padding > 0) reader.readBytes(padding);
}

function skipTlVector(reader: BinaryReader): void {
  // Generic vector skip - skips the vector constructor + count, then blindly skips items
  // This works by reading count and trying to skip each TL object
  const vectorConstructor = reader.readInt() >>> 0;
  if (vectorConstructor !== 0x1cb5c415) {
    throw new Error(`Expected vector constructor, got 0x${vectorConstructor.toString(16)}`);
  }
  const count = reader.readInt();
  for (let i = 0; i < count; i++) {
    skipTlObject(reader);
  }
}

function skipTlObject(reader: BinaryReader): void {
  // Skip a single TL object by reading its constructor and known fixed fields
  // This is a best-effort approach for common types like MessageEntity
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    // messageEntityBold, messageEntityItalic, messageEntityCode, etc.
    // All simple entities have: offset:int length:int
    case 0xbd610bc9: // messageEntityBold
    case 0x826f8b60: // messageEntityItalic
    case 0x28a20571: // messageEntityCode
    case 0x6cef8ac7: // messageEntityUnderline
    case 0xbf0693d4: // messageEntityStrike
    case 0x020df5d0: // messageEntityBlockquote
    case 0xbb92ba95: // messageEntityUnknown
    case 0xfa04579d: // messageEntityMention
    case 0x6f635b0d: // messageEntityHashtag
    case 0x6ed02538: // messageEntityBotCommand
    case 0x73924be0: // messageEntityUrl
    case 0x64e475c2: // messageEntityEmail
    case 0x4c4e743f: // messageEntityCashtag
    case 0x9b69e34b: // messageEntityPhone
    case 0x9c4e7e8b: // messageEntitySpoiler
      reader.readInt(); // offset
      reader.readInt(); // length
      break;
    case 0x76a6d327: // messageEntityTextUrl
      reader.readInt(); // offset
      reader.readInt(); // length
      skipTlStringByReader(reader); // url
      break;
    case 0xdc7b1140: // messageEntityMentionName
      reader.readInt(); // offset
      reader.readInt(); // length
      reader.readLong(); // user_id
      break;
    case 0x32ca960f: // messageEntityPre
      reader.readInt(); // offset
      reader.readInt(); // length
      skipTlStringByReader(reader); // language
      break;
    case 0xc8cf05f8: // messageEntityCustomEmoji
      reader.readInt(); // offset
      reader.readInt(); // length
      reader.readLong(); // document_id
      break;
    default:
      // Unknown entity type - try to skip offset(4) + length(4)
      reader.readInt();
      reader.readInt();
      break;
  }
}

function readInputUserRef(reader: BinaryReader, session?: ClientSession): ParsedUserRef | undefined {
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    case 0xf21158c6: { // inputUser
      const userId = reader.readLong().toString();
      reader.readLong(); // access_hash
      return { userId };
    }
    case 0xf7c1b13f: { // inputUserSelf
      return { userId: String(session?.userId || SEED_USER_ID) };
    }
    default:
      return undefined;
  }
}

function readInputDialogPeerKey(reader: BinaryReader): string | undefined {
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    case 0xfcaafeb7: // inputDialogPeer
      return readInputPeerKey(reader);
    case 0x64600527: // inputDialogPeerFolder
      reader.readInt(); // folder_id
      return undefined;
    default:
      return undefined;
  }
}

function readInputPeerKey(reader: BinaryReader): string | undefined {
  const constructorId = reader.readInt() >>> 0;
  switch (constructorId) {
    case 0xdde8a54c: { // inputPeerUser
      const userId = reader.readLong().toString();
      reader.readLong(); // access_hash
      return `user:${userId}`;
    }
    case 0x35a95cb9: { // inputPeerChat
      return `chat:${reader.readLong().toString()}`;
    }
    case 0x27bcbbfc: { // inputPeerChannel
      const channelId = reader.readLong().toString();
      reader.readLong(); // access_hash
      return `channel:${channelId}`;
    }
    case 0x7da07ec9: { // inputPeerSelf
      return `user:${_activeSession?.userId || SEED_USER_ID}`;
    }
    default:
      return undefined;
  }
}

function readTlString(reader: BinaryReader): string {
  const first = reader.readByte();
  let length = first;

  if (first === 254) {
    const bytes = reader.readBytes(3);
    length = bytes[0] | (bytes[1] << 8) | (bytes[2] << 16);
  }

  const value = reader.readBytes(length).toString('utf-8');
  const headerLength = first === 254 ? 4 : 1;
  const padding = (4 - ((headerLength + length) % 4)) % 4;
  if (padding > 0) {
    reader.readBytes(padding);
  }

  return value;
}

function buildDialogsSliceFromFixture(fixture: OfficialCaptureFixture): Buffer {
  const topMessagesByPeer = new Map<string, FixtureMessage>();
  for (const message of fixture.dialogMessages) {
    const current = topMessagesByPeer.get(message.peerKey);
    if (!current || message.id > current.id) {
      topMessagesByPeer.set(message.peerKey, message);
    }
  }

  const dialogs = fixture.dialogs.map((dialog) => {
    const localMessages = listStoredMessagesAsFixture(dialog.peerKey);
    const mergedMessages = mergeMessagesById([
      ...(topMessagesByPeer.get(dialog.peerKey) ? [topMessagesByPeer.get(dialog.peerKey)!] : []),
      ...localMessages,
    ]);

    return mergeDialogWithMessages(dialog, mergedMessages);
  });
  const topMessages = dialogs
    .map((dialog) => buildTopDialogMessage(dialog.peerKey, topMessagesByPeer.get(dialog.peerKey)))
    .filter((message): message is FixtureMessage => Boolean(message));

  const w = new BinaryWriter();
  // messages.dialogsSlice#71e094f3 count:int dialogs:Vector<Dialog> messages:Vector<Message> chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x71e094f3);
  w.writeInt(dialogs.length);
  writeDialogVector(w, dialogs);
  writeMessageVector(w, topMessages);
  writeChatVector(w, fixture, collectChatIdsFromMessages(fixture.dialogChatIds, topMessages));
  writeUserVector(w, fixture, fixture.dialogUserIds);
  return w.getBytes();
}

function buildPeerDialogsFromFixture(
  fixture: OfficialCaptureFixture,
  peerKey: string,
  dialogs: FixtureDialog[],
  messages: FixtureMessage[],
  userIds: string[],
  chatIds: string[],
): Buffer {
  const mergedMessages = mergeMessagesById([
    ...messages,
    ...listStoredMessagesAsFixture(peerKey),
  ]);
  const mergedDialogs = dialogs.length > 0
    ? dialogs.map((dialog) => mergeDialogWithMessages(dialog, mergedMessages))
    : mergedMessages.length > 0
      ? [createDialogFromMessage(peerKey, mergedMessages[0])]
      : dialogs;

  const w = new BinaryWriter();
  // messages.peerDialogs#3371c354 dialogs:Vector<Dialog> messages:Vector<Message> chats:Vector<Chat> users:Vector<User> state:updates.State
  w.writeInt(0x3371c354);
  writeDialogVector(w, mergedDialogs);
  writeMessageVector(w, mergedMessages.slice(0, Math.max(1, mergedMessages.length)));
  writeChatVector(w, fixture, collectChatIdsFromMessages(chatIds, mergedMessages));
  writeUserVector(w, fixture, userIds);
  writeUpdatesStateToWriter(w);
  return w.getBytes();
}

function buildHistoryFromFixture(
  fixture: OfficialCaptureFixture,
  history: OfficialCaptureFixture['historiesByKey'][string],
  request: ParsedHistoryRequest,
): Buffer {
  const mergedMessages = mergeMessagesById([
    ...history.messages,
    ...listStoredMessagesAsFixture(history.peerKey),
  ]);
  const visibleMessages = sliceHistoryMessages(mergedMessages, request.offsetId, request.limit);

  const w = new BinaryWriter();
  if (history.responseClassName === 'messages.ChannelMessages') {
    // messages.channelMessages#c776ba4e flags:# inexact:flags.1?true pts:int count:int offset_id_offset:flags.2?int messages:Vector<Message> topics:Vector<ForumTopic> chats:Vector<Chat> users:Vector<User>
    w.writeInt(0xc776ba4e);
    w.writeInt(0); // flags
    w.writeInt(history.pts || 0);
    w.writeInt(history.count || mergedMessages.length);
    writeMessageVector(w, visibleMessages);
    writeEmptyVectorToWriter(w); // topics
    writeChatVector(w, fixture, collectChatIdsFromMessages(history.chatIds, mergedMessages));
    writeUserVector(w, fixture, history.userIds);
    return w.getBytes();
  }

  if (history.responseClassName === 'messages.Messages') {
    // messages.messages#1d73e7ea messages:Vector<Message> topics:Vector<ForumTopic> chats:Vector<Chat> users:Vector<User>
    w.writeInt(0x1d73e7ea);
    writeMessageVector(w, visibleMessages);
    writeEmptyVectorToWriter(w); // topics
    writeChatVector(w, fixture, collectChatIdsFromMessages(history.chatIds, mergedMessages));
    writeUserVector(w, fixture, history.userIds);
    return w.getBytes();
  }

  // messages.messagesSlice#5f206716 flags:# inexact:flags.1?true count:int next_rate:flags.0?int offset_id_offset:flags.2?int messages:Vector<Message> topics:Vector<ForumTopic> chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x5f206716);
  w.writeInt(0); // flags
  w.writeInt(history.count || mergedMessages.length);
  writeMessageVector(w, visibleMessages);
  writeEmptyVectorToWriter(w); // topics
  writeChatVector(w, fixture, collectChatIdsFromMessages(history.chatIds, mergedMessages));
  writeUserVector(w, fixture, history.userIds);
  return w.getBytes();
}

function buildMessagesSliceEmpty(): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0x5f206716);
  w.writeInt(0);
  w.writeInt(0);
  writeEmptyVectorToWriter(w); // messages
  writeEmptyVectorToWriter(w); // topics
  writeEmptyVectorToWriter(w); // chats
  writeEmptyVectorToWriter(w); // users
  return w.getBytes();
}

function buildGetMessagesResponse(messages: FixtureMessage[], fixture?: OfficialCaptureFixture | null, selfId?: number): Buffer {
  // messages.messages#1d73e7ea messages:Vector<Message> topics:Vector<ForumTopic> chats:Vector<Chat> users:Vector<User>
  const w = new BinaryWriter();
  w.writeInt(0x1d73e7ea);
  writeMessageVector(w, messages);
  writeEmptyVectorToWriter(w); // topics

  const effectiveSelfId = selfId ?? SEED_USER_ID;
  const userIdSet = new Set<string>([String(effectiveSelfId)]);
  const chatIds: string[] = [];
  for (const msg of messages) {
    collectEntityIdsFromPeerKey(msg.peerKey, [], chatIds);
    if (msg.peerKey.startsWith('user:')) userIdSet.add(msg.peerKey.replace('user:', ''));
    if (msg.fromPeerKey?.startsWith('user:')) userIdSet.add(msg.fromPeerKey.replace('user:', ''));
  }

  if (fixture) {
    writeChatVector(w, fixture, chatIds);
    writeUserVector(w, fixture, Array.from(userIdSet));
  } else {
    writeEmptyVectorToWriter(w); // chats
    // Write users from DB
    const userIds = Array.from(userIdSet);
    w.writeInt(0x1cb5c415);
    w.writeInt(userIds.length);
    for (const userId of userIds) {
      const isSelf = userId === String(effectiveSelfId);
      writeUserFromFixture(w, getFixtureUserForId(undefined, userId, isSelf));
    }
  }
  return w.getBytes();
}

function buildWebPagePreviewEmpty(): Buffer {
  const w = new BinaryWriter();
  // messages.webPagePreview#8c9a88ac media:MessageMedia chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x8c9a88ac);
  // messageMediaEmpty#3ded6320
  w.writeInt(0x3ded6320);
  writeEmptyVectorToWriter(w); // chats
  writeEmptyVectorToWriter(w); // users
  return w.getBytes();
}

function buildMessagesEmpty(): Buffer {
  const w = new BinaryWriter();
  // messages.messages#1d73e7ea messages:Vector<Message> topics:Vector<ForumTopic> chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x1d73e7ea);
  writeEmptyVectorToWriter(w); // messages
  writeEmptyVectorToWriter(w); // topics
  writeEmptyVectorToWriter(w); // chats
  writeEmptyVectorToWriter(w); // users
  return w.getBytes();
}

function buildRecentStoriesVector(count: number): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0x1cb5c415);
  w.writeInt(count);
  for (let index = 0; index < count; index++) {
    w.writeInt(0x711d692d); // recentStory
    w.writeInt(0); // flags
  }
  return w.getBytes();
}

function getReadStateForPeerKey(peerKey: string, selfId: number, fixtureDialog?: FixtureDialog) {
  const stored = messageStore.getPeerState(selfId, peerKey);

  return {
    readInboxMaxId: Math.max(fixtureDialog?.readInboxMaxId || 0, stored?.readInboxMaxId || 0),
    readOutboxMaxId: Math.max(fixtureDialog?.readOutboxMaxId || 0, stored?.readOutboxMaxId || 0),
  };
}

function listStoredMessagesAsFixture(peerKey: string, selfId: number = SEED_USER_ID): FixtureMessage[] {
  const isSavedMessages = peerKey === `user:${selfId}`;
  return messageStore.listMessages(selfId, peerKey).map((message) => ({
    id: message.messageId,
    peerKey: message.peerKey,
    date: message.date,
    text: message.text,
    className: 'Message',
    out: isSavedMessages ? false : message.isOutgoing,
    post: message.post,
    fromPeerKey: isSavedMessages ? undefined : message.fromPeerKey,
    savedPeerKey: isSavedMessages ? `user:${SEED_USER_ID}` : undefined,
    editDate: message.editDate,
  }));
}

function listStoredMessagesAsFixtureForUser(peerKey: string, userId: number): FixtureMessage[] {
  const isSavedMessages = peerKey === `user:${userId}`;
  return messageStore.listMessagesForUser(peerKey, userId).map((message) => ({
    id: message.messageId,
    peerKey: message.peerKey,
    date: message.date,
    text: message.text,
    className: 'Message',
    out: isSavedMessages ? false : message.isOutgoing,
    post: message.post,
    fromPeerKey: isSavedMessages ? undefined : message.fromPeerKey,
    savedPeerKey: isSavedMessages ? `user:${userId}` : undefined,
    editDate: message.editDate,
  }));
}

function getStoredMessageAsFixture(peerKey: string, messageId: number, selfId?: number): FixtureMessage | undefined {
  const effectiveSelfId = selfId ?? SEED_USER_ID;
  const message = messageStore.getMessage(effectiveSelfId, peerKey, messageId);
  if (!message) {
    return undefined;
  }

  const isSavedMessages = peerKey === `user:${effectiveSelfId}`;
  return {
    id: message.messageId,
    peerKey: message.peerKey,
    date: message.date,
    text: message.text,
    className: 'Message',
    out: isSavedMessages ? false : message.isOutgoing,
    post: message.post,
    fromPeerKey: isSavedMessages ? undefined : message.fromPeerKey,
    savedPeerKey: isSavedMessages ? `user:${effectiveSelfId}` : undefined,
    editDate: message.editDate,
  };
}

function mergeMessagesById(messages: FixtureMessage[]): FixtureMessage[] {
  const uniqueMessages = new Map<number, FixtureMessage>();
  for (const message of messages) {
    uniqueMessages.set(message.id, message);
  }

  return Array.from(uniqueMessages.values())
    .sort((left, right) => (right.id - left.id) || (right.date - left.date));
}

function mergeDialogWithMessages(dialog: FixtureDialog, messages: FixtureMessage[]): FixtureDialog {
  const topMessage = messages[0];
  const mergedDialog = !topMessage ? dialog : {
    ...dialog,
    topMessage: topMessage.id,
    readOutboxMaxId: topMessage.out
      ? Math.max(dialog.readOutboxMaxId, topMessage.id)
      : dialog.readOutboxMaxId,
    readInboxMaxId: topMessage.out && dialog.peerKey === `user:${SEED_USER_ID}`
      ? Math.max(dialog.readInboxMaxId, topMessage.id)
      : dialog.readInboxMaxId,
  };

  return applyStoredDialogState(mergedDialog);
}

function buildTopDialogMessage(peerKey: string, baseMessage?: FixtureMessage): FixtureMessage | undefined {
  const mergedMessages = mergeMessagesById([
    ...(baseMessage ? [baseMessage] : []),
    ...listStoredMessagesAsFixture(peerKey),
  ]);

  return mergedMessages[0];
}

function createDialogFromMessage(peerKey: string, message: FixtureMessage): FixtureDialog {
  return applyStoredDialogState({
    peerKey,
    topMessage: message.id,
    readInboxMaxId: peerKey === `user:${SEED_USER_ID}` ? message.id : 0,
    readOutboxMaxId: message.out ? message.id : 0,
    unreadCount: 0,
    unreadMentionsCount: 0,
    unreadReactionsCount: 0,
  });
}

function sliceHistoryMessages(messages: FixtureMessage[], offsetId: number, limit: number): FixtureMessage[] {
  const filteredMessages = offsetId > 0
    ? messages.filter((message) => message.id < offsetId)
    : messages;

  return filteredMessages.slice(0, limit > 0 ? limit : filteredMessages.length);
}

function collectChatIdsFromMessages(baseChatIds: string[], messages: FixtureMessage[]): string[] {
  const derivedChatIds = messages
    .filter((message) => message.peerKey.startsWith('channel:') || message.peerKey.startsWith('chat:'))
    .map((message) => message.peerKey.split(':', 2)[1]);

  return Array.from(new Set([...baseChatIds, ...derivedChatIds]));
}

function collectUserIdsFromMessages(baseUserIds: string[], messages: FixtureMessage[]): string[] {
  const peerUserIds = messages
    .filter((message) => message.peerKey.startsWith('user:'))
    .map((message) => message.peerKey.split(':', 2)[1]);
  const fromUserIds = messages
    .filter((message) => message.fromPeerKey?.startsWith('user:'))
    .map((message) => message.fromPeerKey!.split(':', 2)[1]);

  return Array.from(new Set([...baseUserIds, ...peerUserIds, ...fromUserIds]));
}

function collectEntityIdsFromPeerKey(peerKey: string, userIds: string[], chatIds: string[]) {
  if (peerKey.startsWith('user:')) {
    userIds.push(peerKey.split(':', 2)[1]);
    return;
  }

  if (peerKey.startsWith('channel:') || peerKey.startsWith('chat:')) {
    chatIds.push(peerKey.split(':', 2)[1]);
  }
}

function getHighestObservedMessageId(fixture: OfficialCaptureFixture, peerKey: string): number {
  const dialogMax = fixture.dialogs
    .filter((dialog) => dialog.peerKey === peerKey)
    .reduce((max, dialog) => Math.max(max, dialog.topMessage), 0);
  const dialogMessagesMax = fixture.dialogMessages
    .filter((message) => message.peerKey === peerKey)
    .reduce((max, message) => Math.max(max, message.id), 0);
  const historyMessagesMax = Object.values(fixture.historiesByKey)
    .filter((history) => history.peerKey === peerKey)
    .flatMap((history) => history.messages)
    .reduce((max, message) => Math.max(max, message.id), 0);

  return Math.max(dialogMax, dialogMessagesMax, historyMessagesMax);
}

function applyStoredDialogState(dialog: FixtureDialog, selfId: number = SEED_USER_ID): FixtureDialog {
  const state = messageStore.getPeerState(selfId, dialog.peerKey);
  if (!state) {
    return dialog;
  }

  return {
    ...dialog,
    readInboxMaxId: Math.max(dialog.readInboxMaxId, state.readInboxMaxId),
    readOutboxMaxId: Math.max(dialog.readOutboxMaxId, state.readOutboxMaxId),
  };
}

function writeDialogVector(w: BinaryWriter, dialogs: FixtureDialog[]): void {
  w.writeInt(0x1cb5c415);
  w.writeInt(dialogs.length);
  for (const dialog of dialogs) {
    writeDialogFromFixture(w, dialog);
  }
}

function writeMessageVector(w: BinaryWriter, messages: FixtureMessage[]): void {
  w.writeInt(0x1cb5c415);
  w.writeInt(messages.length);
  for (const message of messages) {
    writeMessageFromFixture(w, message);
  }
}

function writeUserVector(w: BinaryWriter, fixture: OfficialCaptureFixture, userIds: string[]): void {
  const uniqueUserIds = Array.from(new Set(userIds));
  w.writeInt(0x1cb5c415);
  w.writeInt(uniqueUserIds.length);
  for (const userId of uniqueUserIds) {
    const user = fixture.usersById[userId];
    if (user) {
      writeUserFromFixture(w, user);
      continue;
    }

    writeFallbackUserFromId(w, userId);
  }
}

function writeChatVector(w: BinaryWriter, fixture: OfficialCaptureFixture, chatIds: string[]): void {
  const chats = Array.from(new Set(chatIds))
    .map((chatId) => fixture.chatsById[chatId])
    .filter((chat): chat is FixtureChat => Boolean(chat));
  w.writeInt(0x1cb5c415);
  w.writeInt(chats.length);
  for (const chat of chats) {
    writeChatFromFixture(w, chat);
  }
}

function writeDialogFromFixture(w: BinaryWriter, dialog: FixtureDialog): void {
  // dialog#d58a08c6 flags:# pinned:flags.2?true unread_mark:flags.3?true view_forum_as_messages:flags.6?true peer:Peer top_message:int read_inbox_max_id:int read_outbox_max_id:int unread_count:int unread_mentions_count:int unread_reactions_count:int notify_settings:PeerNotifySettings ...
  w.writeInt(0xd58a08c6);
  let flags = 0;
  if (dialog.pts !== undefined) flags |= (1 << 0);
  if (dialog.draftDate !== undefined) flags |= (1 << 1);
  w.writeInt(flags);
  writePeerByKey(w, dialog.peerKey);
  w.writeInt(dialog.topMessage);
  w.writeInt(dialog.readInboxMaxId);
  w.writeInt(dialog.readOutboxMaxId);
  w.writeInt(dialog.unreadCount);
  w.writeInt(dialog.unreadMentionsCount);
  w.writeInt(dialog.unreadReactionsCount);
  writePeerNotifySettingsToWriter(w);
  if (dialog.pts !== undefined) {
    w.writeInt(dialog.pts);
  }
  if (dialog.draftDate !== undefined) {
    writeDraftMessageEmpty(w, dialog.draftDate);
  }
}

function writeMessageFromFixture(w: BinaryWriter, message: FixtureMessage): void {
  // message#3ae56482 flags:# ... flags2:# id:int from_id:flags.8?Peer from_boosts_applied:flags.29?int
  // from_rank:flags2.12?string peer_id:Peer saved_peer_id:flags.28?Peer ... date:int message:string ...
  w.writeInt(0x3ae56482);
  let flags = 0;
  if (message.out) flags |= (1 << 1);
  if (message.fromPeerKey) flags |= (1 << 8);
  if (message.post) flags |= (1 << 14);
  if (message.editDate) flags |= (1 << 15);
  if (message.savedPeerKey) flags |= (1 << 28);
  w.writeInt(flags);
  w.writeInt(0); // flags2
  w.writeInt(message.id);
  if (message.fromPeerKey) {
    writePeerByKey(w, message.fromPeerKey);
  }
  writePeerByKey(w, message.peerKey);
  if (message.savedPeerKey) {
    writePeerByKey(w, message.savedPeerKey);
  }
  w.writeInt(message.date);
  writeTlString(w, message.text);
  if (message.editDate) {
    w.writeInt(message.editDate);
  }
}

function writeUserFromFixture(w: BinaryWriter, user: FixtureUser): void {
  let flags = 0;
  if (user.accessHash) flags |= (1 << 0);
  if (user.firstName) flags |= (1 << 1);
  if (user.lastName) flags |= (1 << 2);
  if (user.username) flags |= (1 << 3);
  if (user.phone) flags |= (1 << 4);
  flags |= (1 << 6); // always include status
  if (user.self) flags |= (1 << 10); // self

  w.writeInt(0x31774388);
  w.writeInt(flags);
  w.writeInt(1 << 4); // flags2 stories_unavailable
  w.writeLong(BigInt(user.id));
  if (user.accessHash) {
    w.writeLong(BigInt(user.accessHash));
  }
  if (user.firstName) {
    writeTlString(w, user.firstName);
  }
  if (user.lastName) {
    writeTlString(w, user.lastName);
  }
  if (user.username) {
    writeTlString(w, user.username);
  }
  if (user.phone) {
    writeTlString(w, user.phone);
  }
  // status: always written (flag bit 6 always set)
  // userStatusOnline#edb93949 expires:int
  w.writeInt(0xedb93949);
  w.writeInt(Math.floor(Date.now() / 1000) + 300);
}

function writeFallbackUserFromId(w: BinaryWriter, userId: string): void {
  writeUserFromFixture(w, {
    id: userId,
    accessHash: '0',
    firstName: 'User',
  });
}

function writeChatFromFixture(w: BinaryWriter, chat: FixtureChat): void {
  if (chat.className === 'Channel') {
    writeChannelFromFixture(w, chat);
  }
}

function writeChannelFromFixture(w: BinaryWriter, chat: FixtureChat): void {
  let flags = 0;
  if (chat.creator) flags |= (1 << 0);
  if (chat.broadcast) flags |= (1 << 5);
  if (chat.username) flags |= (1 << 6);
  if (chat.accessHash) flags |= (1 << 13);

  w.writeInt(0x1c32b11c);
  w.writeInt(flags);
  w.writeInt(0); // flags2
  w.writeLong(BigInt(chat.id));
  if (chat.accessHash) {
    w.writeLong(BigInt(chat.accessHash));
  }
  writeTlString(w, chat.title);
  if (chat.username) {
    writeTlString(w, chat.username);
  }
  writeChatPhotoEmpty(w);
  w.writeInt(chat.date);
}

function writePeerByKey(w: BinaryWriter, peerKey: string): void {
  const [type, rawId] = peerKey.split(':');
  const id = BigInt(rawId || '0');

  switch (type) {
    case 'user':
      w.writeInt(0x59511722); // peerUser
      w.writeLong(id);
      return;
    case 'chat':
      w.writeInt(0x36c6019a); // peerChat
      w.writeLong(id);
      return;
    case 'channel':
      w.writeInt(0xa2a5371e); // peerChannel
      w.writeLong(id);
      return;
    default:
      w.writeInt(0x59511722);
      w.writeLong(id);
  }
}

function writePeerNotifySettingsToWriter(w: BinaryWriter): void {
  // peerNotifySettings#99622c0c flags:#
  //   show_previews:flags.0?Bool silent:flags.1?Bool mute_until:flags.2?int
  //   ios_sound:flags.3?NotificationSound android_sound:flags.4?NotificationSound other_sound:flags.5?NotificationSound
  w.writeInt(0x99622c0c);
  const flags = (1 << 0) | (1 << 1) | (1 << 2) | (1 << 3) | (1 << 4) | (1 << 5); // 63
  w.writeInt(flags);
  w.writeInt(0x997275b5); // show_previews = boolTrue
  w.writeInt(0xbc799737); // silent = boolFalse
  w.writeInt(0);          // mute_until = 0
  // ios_sound: notificationSoundDefault#97e8bebe
  w.writeInt(0x97e8bebe);
  // android_sound: notificationSoundLocal#830b9ae4 title:"default" data:"default"
  w.writeInt(0x830b9ae4);
  writeTlString(w, 'default');
  writeTlString(w, 'default');
  // other_sound: notificationSoundLocal#830b9ae4 title:"default" data:"default"
  w.writeInt(0x830b9ae4);
  writeTlString(w, 'default');
  writeTlString(w, 'default');
}

function writeDraftMessageEmpty(w: BinaryWriter, date: number): void {
  // draftMessageEmpty#1b0c841a flags:# date:int
  w.writeInt(0x1b0c841a);
  w.writeInt(1);
  w.writeInt(date);
}

function writeChatPhotoEmpty(w: BinaryWriter): void {
  w.writeInt(0x37c1011c);
}

function writePhotoEmpty(w: BinaryWriter, photoId: bigint): void {
  // photoEmpty#2331b22d id:long
  w.writeInt(0x2331b22d);
  w.writeLong(photoId);
}

function writeEmptyVectorToWriter(w: BinaryWriter): void {
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
}

function writeBufferVector(w: BinaryWriter, items: Buffer[]): void {
  w.writeInt(0x1cb5c415);
  w.writeInt(items.length);
  for (const item of items) {
    w.writeBytes(item);
  }
}

function writeUpdatesStateToWriter(w: BinaryWriter): void {
  const state = messageStore.getUpdateState();
  w.writeInt(0xa56c2a3e);
  w.writeInt(state.pts);
  w.writeInt(state.qts);
  w.writeInt(state.date);
  w.writeInt(state.seq);
  w.writeInt(state.unreadCount);
}

function writeEmptyJsonObject(w: BinaryWriter): void {
  // jsonObject#99c1d49d value:Vector<JSONObjectValue>
  w.writeInt(0x99c1d49d);
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
}

function buildConfig(): Buffer {
  const w = new BinaryWriter();
  // config#cc1a241e flags:# ... = Config
  // flags.0 = tmp_sessions present
  // No optional flags set for now (flags = 0)
  w.writeInt(0xcc1a241e);  // config constructor
  w.writeInt(0);           // flags (no optional fields)
  w.writeInt(Math.floor(Date.now() / 1000)); // date
  w.writeInt(Math.floor(Date.now() / 1000) + 3600); // expires
  w.writeInt(0xbc799737); // test_mode = boolFalse#bc799737
  w.writeInt(2);           // this_dc

  // dc_options: Vector<DcOption>
  w.writeInt(0x1cb5c415);  // vector constructor
  w.writeInt(1);           // count = 1
  // dcOption#18b7a10d flags:# id:int ip_address:string port:int
  w.writeInt(0x18b7a10d);
  w.writeInt(0);           // flags
  w.writeInt(2);           // id = 2
  writeTlString(w, '127.0.0.1');
  w.writeInt(8080);        // port

  writeTlString(w, '');    // dc_txt_domain_name
  w.writeInt(200);         // chat_size_max
  w.writeInt(200000);      // megagroup_size_max
  w.writeInt(100);         // forwarded_count_max
  w.writeInt(60000);       // online_update_period_ms
  w.writeInt(5000);        // offline_blur_timeout_ms
  w.writeInt(30000);       // offline_idle_timeout_ms
  w.writeInt(300000);      // online_cloud_timeout_ms
  w.writeInt(1500);        // notify_cloud_delay_ms
  w.writeInt(25000);       // notify_default_delay_ms
  w.writeInt(60000);       // push_chat_period_ms
  w.writeInt(2);           // push_chat_limit
  w.writeInt(172800);      // edit_time_limit
  w.writeInt(2147483647);  // revoke_time_limit
  w.writeInt(2147483647);  // revoke_pm_time_limit
  w.writeInt(2419200);     // rating_e_decay
  w.writeInt(200);         // stickers_recent_limit
  w.writeInt(604800);      // channels_read_media_period
  // tmp_sessions: flags.0 — NOT present (flag 0 not set)
  w.writeInt(60);          // call_receive_timeout_ms
  w.writeInt(60);          // call_ring_timeout_ms
  w.writeInt(30);          // call_connect_timeout_ms
  w.writeInt(10);          // call_packet_timeout_ms
  writeTlString(w, 'https://localhost/'); // me_url_prefix
  // autoupdate_url_prefix: flags.7 — NOT present
  // gif_search_username: flags.9 — NOT present
  // venue_search_username: flags.10 — NOT present
  // img_search_username: flags.11 — NOT present
  // static_maps_provider: flags.12 — NOT present
  w.writeInt(1024);        // caption_length_max
  w.writeInt(4096);        // message_length_max
  w.writeInt(2);           // webfile_dc_id
  // suggested_lang_code: flags.2 — NOT present
  // lang_pack_version: flags.2 — NOT present
  // base_lang_pack_version: flags.2 — NOT present
  // reactions_default: flags.15 — NOT present
  // autologin_token: flags.16 — NOT present

  return w.getBytes();
}

function buildAppConfig(): Buffer {
  const w = new BinaryWriter();
  // help.appConfig#dd18782e hash:int config:JSONValue
  w.writeInt(0xdd18782e);
  w.writeInt(0); // hash
  writeEmptyJsonObject(w);
  return w.getBytes();
}

function buildUpdatesState(): Buffer {
  const w = new BinaryWriter();
  // updates.state#a56c2a3e pts:int qts:int date:int seq:int unread_count:int
  writeUpdatesStateToWriter(w);
  return w.getBytes();
}

const langPackCache = new Map<string, Record<string, string>>();
function loadLangPackStrings(packName: string): Record<string, string> {
  const cached = langPackCache.get(packName);
  if (cached) return cached;

  // Try pack-specific file first, then fall back to langpack-en.json
  const candidates = [
    resolvePath(process.cwd(), 'data', `langpack-${packName}.json`),
    resolvePath(process.cwd(), 'data', 'langpack-en.json'),
  ];

  for (const langPackPath of candidates) {
    if (existsSync(langPackPath)) {
      try {
        const strings = JSON.parse(readFileSync(langPackPath, 'utf8'));
        console.log(`[LangPack] Loaded ${Object.keys(strings).length} strings for "${packName}" from ${langPackPath}`);
        langPackCache.set(packName, strings);
        return strings;
      } catch (e) {
        console.error(`[LangPack] Failed to load ${langPackPath}:`, e);
      }
    }
  }

  console.warn(`[LangPack] No langpack file for "${packName}" — run scripts/generate-langpack.cjs`);
  const empty = {};
  langPackCache.set(packName, empty);
  return empty;
}

function buildLangPackDifference(packName: string = 'weba'): Buffer {
  const strings = loadLangPackStrings(packName);
  const entries = Object.entries(strings);

  const w = new BinaryWriter();
  // langPackDifference#f385c1f6 lang_code:string from_version:int version:int strings:Vector<LangPackString>
  w.writeInt(0xf385c1f6);
  writeTlString(w, 'en');  // lang_code
  w.writeInt(0);            // from_version
  w.writeInt(1);            // version
  // strings: Vector<LangPackString>
  w.writeInt(0x1cb5c415);
  w.writeInt(entries.length);
  for (const [key, value] of entries) {
    // langPackString#cad181f6 key:string value:string
    w.writeInt(0xcad181f6);
    writeTlString(w, key);
    writeTlString(w, value);
  }
  return w.getBytes();
}

function buildLangPackStringsResponse(packName: string, keys: string[]): Buffer {
  const strings = loadLangPackStrings(packName);
  const w = new BinaryWriter();
  // Vector<LangPackString>
  w.writeInt(0x1cb5c415);
  w.writeInt(keys.length);
  for (const key of keys) {
    const value = strings[key];
    if (value !== undefined) {
      // langPackString#cad181f6 key:string value:string
      w.writeInt(0xcad181f6);
      writeTlString(w, key);
      writeTlString(w, value);
    } else {
      // langPackStringDeleted#2979eeb2 key:string
      w.writeInt(0x2979eeb2);
      writeTlString(w, key);
    }
  }
  return w.getBytes();
}

function buildLangPackLanguage(): Buffer {
  const w = new BinaryWriter();
  // langPackLanguage#eeca5ce3 flags:# official:flags.0?true rtl:flags.2?true beta:flags.3?true
  // name:string native_name:string lang_code:string base_lang_code:flags.1?string
  // plural_code:string strings_count:int translated_count:int translations_url:string
  w.writeInt(0xeeca5ce3);
  w.writeInt(1);             // flags (official = true)
  writeTlString(w, 'English');  // name
  writeTlString(w, 'English');  // native_name
  writeTlString(w, 'en');       // lang_code
  // base_lang_code: flags.1 — NOT present
  writeTlString(w, 'en');       // plural_code
  w.writeInt(0);                // strings_count
  w.writeInt(0);                // translated_count
  writeTlString(w, '');         // translations_url
  return w.getBytes();
}

function buildEmptyVector(): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0x1cb5c415);  // vector constructor
  w.writeInt(0);            // count = 0
  return w.getBytes();
}

function buildUpdatesDifferenceEmpty(): Buffer {
  const state = messageStore.getUpdateState();
  const w = new BinaryWriter();
  // updates.differenceEmpty#5d75a138 date:int seq:int
  w.writeInt(0x5d75a138);
  w.writeInt(state.date);
  w.writeInt(state.seq);
  return w.getBytes();
}

function buildUpdatesDifference(data: Buffer, selfId: number): Buffer {
  const request = parseUpdatesDifferenceRequest(data);
  const currentState = messageStore.getUpdateState();
  const fromPts = request?.pts ?? currentState.pts;
  const events = messageStore.listUpdateEventsAfter(fromPts);

  if (!events.length) {
    return buildUpdatesDifferenceEmpty();
  }

  const newMessages: FixtureMessage[] = [];
  const otherUpdates: Buffer[] = [];
  const userIds: string[] = [];
  const chatIds: string[] = [];

  const seenMessageIds = new Set<number>();

  for (const event of events) {
    collectEntityIdsFromPeerKey(event.peerKey, userIds, chatIds);

    if (event.kind === 'new_message' && event.messageId !== undefined) {
      // Use getMessageForUser to find the correct copy for this user
      // This filters out events that belong to the other user's copy
      const stored = messageStore.getMessageForUser(event.messageId, selfId);
      if (stored && !seenMessageIds.has(stored.messageId)) {
        seenMessageIds.add(stored.messageId);
        const isSavedMessages = stored.peerKey === `user:${selfId}`;
        const message: FixtureMessage = {
          id: stored.messageId,
          peerKey: stored.peerKey,
          date: stored.date,
          text: stored.text,
          className: 'Message',
          out: isSavedMessages ? false : stored.isOutgoing,
          post: stored.post,
          fromPeerKey: isSavedMessages ? undefined : stored.fromPeerKey,
          savedPeerKey: isSavedMessages ? `user:${selfId}` : undefined,
          editDate: stored.editDate,
        };
        newMessages.push(message);
        collectEntityIdsFromPeerKey(message.peerKey, userIds, chatIds);
        if (message.fromPeerKey) {
          collectEntityIdsFromPeerKey(message.fromPeerKey, userIds, chatIds);
        }
      }
      continue;
    }

    if (event.kind === 'edit_message' && event.messageId !== undefined) {
      const editedMsg = messageStore.getMessageForUser(event.messageId, selfId);
      if (editedMsg && !seenMessageIds.has(editedMsg.messageId)) {
        seenMessageIds.add(editedMsg.messageId);
        const isSavedMessages = editedMsg.peerKey === `user:${selfId}`;
        const editFixture: FixtureMessage = {
          id: editedMsg.messageId,
          peerKey: editedMsg.peerKey,
          date: editedMsg.date,
          text: editedMsg.text,
          className: 'Message',
          out: isSavedMessages ? false : editedMsg.isOutgoing,
          post: editedMsg.post,
          fromPeerKey: isSavedMessages ? undefined : editedMsg.fromPeerKey,
          savedPeerKey: isSavedMessages ? `user:${selfId}` : undefined,
          editDate: editedMsg.editDate,
        };
        otherUpdates.push(buildUpdateEditMessage(editFixture, event.pts, event.ptsCount));
        if (editFixture.fromPeerKey) {
          collectEntityIdsFromPeerKey(editFixture.fromPeerKey, userIds, chatIds);
        }
      }
      continue;
    }

    if (event.kind === 'delete_messages' && event.messageId !== undefined) {
      otherUpdates.push(buildUpdateDeleteMessages([event.messageId], event.pts, event.ptsCount));
      continue;
    }

    if (event.kind === 'read_history' && event.maxId !== undefined && !event.peerKey.startsWith('channel:')) {
      otherUpdates.push(buildUpdateReadHistoryInbox(event.peerKey, event.maxId, event.pts, event.ptsCount));
    }

    if (event.kind === 'read_history_outbox' && event.maxId !== undefined && !event.peerKey.startsWith('channel:')) {
      otherUpdates.push(buildUpdateReadHistoryOutbox(event.peerKey, event.maxId, event.pts, event.ptsCount));
    }
  }

  const mergedMessages = mergeMessagesById(newMessages);
  const resolvedUserIds = collectUserIdsFromMessages(userIds, mergedMessages);
  const resolvedChatIds = collectChatIdsFromMessages(chatIds, mergedMessages);

  const w = new BinaryWriter();
  // updates.difference#00f49ca0 new_messages:Vector<Message> new_encrypted_messages:Vector<EncryptedMessage> other_updates:Vector<Update> chats:Vector<Chat> users:Vector<User> state:updates.State
  w.writeInt(0x00f49ca0);
  writeMessageVector(w, mergedMessages);
  writeEmptyVectorToWriter(w); // new_encrypted_messages
  writeBufferVector(w, otherUpdates);

  writeEmptyVectorToWriter(w); // chats

  // users
  const allUserIds = Array.from(new Set([String(selfId), ...resolvedUserIds]));
  w.writeInt(0x1cb5c415);
  w.writeInt(allUserIds.length);
  for (const userId of allUserIds) {
    const isSelf = userId === String(selfId);
    writeUserFromFixture(w, getFixtureUserForId(undefined, userId, isSelf));
  }

  writeUpdatesStateToWriter(w);
  return w.getBytes();
}

function buildUpdateReadHistoryInbox(peerKey: string, maxId: number, pts: number, ptsCount: number, selfId?: number): Buffer {
  const w = new BinaryWriter();
  // updateReadHistoryInbox#9e84bc99 flags:# folder_id:flags.0?int peer:Peer top_msg_id:flags.1?int max_id:int still_unread_count:int pts:int pts_count:int
  w.writeInt(0x9e84bc99);
  w.writeInt(0); // flags=0 (no folder_id, no top_msg_id)
  writePeerByKey(w, peerKey);
  w.writeInt(maxId);
  const stillUnread = selfId ? messageStore.getUnreadCount(selfId, peerKey) : 0;
  w.writeInt(stillUnread); // still_unread_count
  w.writeInt(pts);
  w.writeInt(ptsCount);
  return w.getBytes();
}

function buildUpdateReadHistoryOutbox(peerKey: string, maxId: number, pts: number, ptsCount: number): Buffer {
  const w = new BinaryWriter();
  // updateReadHistoryOutbox#2f2f21bf peer:Peer max_id:int pts:int pts_count:int
  w.writeInt(0x2f2f21bf);
  writePeerByKey(w, peerKey);
  w.writeInt(maxId);
  w.writeInt(pts);
  w.writeInt(ptsCount);
  return w.getBytes();
}

// ========== PRIORITY 1 BUILDERS ==========

function buildUserFull(session: ClientSession): Buffer {
  return buildUserFullForUser(session, undefined, String(session.userId || SEED_USER_ID));
}

function buildUserFullForUser(
  session: ClientSession,
  fixture: OfficialCaptureFixture | undefined,
  userId: string,
): Buffer {
  const w = new BinaryWriter();
  // users.userFull#3b6d152e full_user:UserFull chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x3b6d152e);
  const user = getFixtureUserForId(fixture, userId);
  
  // --- UserFull ---
  // userFull#a02bc13e flags:# ... flags2:# id:long settings:PeerSettings
  // notify_settings:PeerNotifySettings common_chats_count:int ...
  // id:long about:flags.1?string settings:PeerSettings 
  // personal_photo:flags.21?Photo profile_photo:flags.2?Photo fallback_photo:flags.22?Photo
  // notify_settings:PeerNotifySettings ...
  w.writeInt(0xa02bc13e);
  w.writeInt(0);           // flags
  w.writeInt(0);           // flags2
  w.writeLong(BigInt(user.id));
  // about: flags.1 — NOT present
  // settings: PeerSettings
  w.writeInt(0xf47741f7);  // peerSettings#f47741f7 flags:#
  w.writeInt(0);
  // personal_photo: flags.21 — NOT present
  // profile_photo: flags.2 — NOT present
  // fallback_photo: flags.22 — NOT present
  // notify_settings: PeerNotifySettings
  writePeerNotifySettingsToWriter(w);
  // common_chats_count
  w.writeInt(0);
  // Remaining required fields skipped via flags=0

  // --- chats: Vector<Chat> ---
  w.writeInt(0x1cb5c415); // vector constructor
  w.writeInt(0);           // count = 0

  // --- users: Vector<User> ---
  w.writeInt(0x1cb5c415); // vector constructor
  w.writeInt(1);           // count = 1
  writeUserFromFixture(w, user);

  return w.getBytes();
}

function writeUser(w: BinaryWriter, session: ClientSession): void {
  writeUserFromFixture(w, getFixtureUserForId(undefined, String(session.userId || SEED_USER_ID)));
}

function getFixtureUserForId(
  fixture: OfficialCaptureFixture | undefined,
  userId: string,
  isSelf?: boolean,
): FixtureUser {
  const fixtureUser = fixture?.usersById[userId];
  if (fixtureUser) {
    return fixtureUser;
  }

  // Look up user in database
  const dbUser = messageStore.getUserById(Number(userId));
  if (dbUser) {
    return {
      id: String(dbUser.id),
      accessHash: dbUser.accessHash.toString(),
      firstName: dbUser.firstName,
      lastName: dbUser.lastName || undefined,
      username: dbUser.username,
      phone: dbUser.phone,
      self: isSelf,
    };
  }

  return {
    id: userId,
    accessHash: '0',
    firstName: 'User',
  };
}

function writeSeedUser(w: BinaryWriter, session: ClientSession): void {
  const userId = session.userId || SEED_USER_ID;
  const user = getFixtureUserForId(undefined, String(userId), true);
  // Use writeUserFromFixture which handles all fields properly
  writeUserFromFixture(w, { ...user, self: true });
}

function buildUsersVector(session: ClientSession): Buffer {
  return buildUsersVectorForIds(session, undefined, [String(session.userId || SEED_USER_ID)]);
}

function buildUsersVectorForIds(
  session: ClientSession,
  fixture: OfficialCaptureFixture | undefined,
  userIds: string[],
): Buffer {
  const w = new BinaryWriter();
  // Vector<User>
  w.writeInt(0x1cb5c415);  // vector constructor
  const uniqueUserIds = Array.from(new Set(userIds));
  w.writeInt(uniqueUserIds.length);
  for (const userId of uniqueUserIds) {
    if (userId === String(SEED_USER_ID) && !fixture?.usersById[userId]) {
      writeSeedUser(w, session);
      continue;
    }

    writeUserFromFixture(w, getFixtureUserForId(fixture, userId));
  }
  return w.getBytes();
}

function buildDialogFilters(): Buffer {
  const w = new BinaryWriter();
  // messages.dialogFilters#2ad93719 flags:# tags_enabled:flags.0?true filters:Vector<DialogFilter>
  w.writeInt(0x2ad93719);
  w.writeInt(0);
  // filters: Vector<DialogFilter>
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  return w.getBytes();
}

function buildDialogsEmpty(): Buffer {
  const w = new BinaryWriter();
  // messages.dialogs#15ba6c40 dialogs:Vector<Dialog> messages:Vector<Message> 
  // chats:Vector<Chat> users:Vector<User>
  w.writeInt(0x15ba6c40);
  // dialogs: empty vector
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  // messages: empty vector
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  // chats: empty vector
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  // users: empty vector
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  return w.getBytes();
}

function buildDialogsFromDb(selfId: number): Buffer {
  const peerKeys = messageStore.getDialogPeerKeysForUser(selfId);
  if (peerKeys.length === 0) return buildDialogsEmpty();

  // Collect dialog data
  const dialogData: Array<{
    peerKey: string;
    topMessage: StoredMessage;
  }> = [];
  const userIdSet = new Set<string>([String(selfId)]);

  for (const peerKey of peerKeys) {
    const lastMsg = messageStore.getLastMessageForUser(peerKey, selfId);
    if (!lastMsg) continue;
    dialogData.push({ peerKey, topMessage: lastMsg });
    // Collect user IDs from peer key
    if (peerKey.startsWith('user:')) {
      userIdSet.add(peerKey.replace('user:', ''));
    }
    if (lastMsg.fromPeerKey?.startsWith('user:')) {
      userIdSet.add(lastMsg.fromPeerKey.replace('user:', ''));
    }
  }

  // Sort by last message date descending
  dialogData.sort((a, b) => b.topMessage.date - a.topMessage.date);

  const w = new BinaryWriter();
  // messages.dialogs#15ba6c40
  w.writeInt(0x15ba6c40);

  // dialogs: Vector<Dialog>
  w.writeInt(0x1cb5c415);
  w.writeInt(dialogData.length);
  for (const { peerKey, topMessage } of dialogData) {
    const peerState = messageStore.getPeerState(selfId, peerKey);
    // dialog#d58a08c6 flags:# peer:Peer top_message:int read_inbox_max_id:int
    //   read_outbox_max_id:int unread_count:int unread_mentions_count:int
    //   unread_reactions_count:int notify_settings:PeerNotifySettings
    w.writeInt(0xd58a08c6);
    w.writeInt(0); // flags (no pinned, no draft, no folder, no ttl)
    writePeerByKey(w, peerKey);
    w.writeInt(topMessage.messageId); // top_message
    w.writeInt(peerState?.readInboxMaxId || 0); // read_inbox_max_id
    w.writeInt(peerState?.readOutboxMaxId || 0); // read_outbox_max_id
    const unreadCount = messageStore.getUnreadCount(selfId, peerKey);
    w.writeInt(unreadCount); // unread_count
    w.writeInt(0); // unread_mentions_count
    w.writeInt(0); // unread_reactions_count
    writePeerNotifySettingsToWriter(w);
  }

  // messages: Vector<Message>
  w.writeInt(0x1cb5c415);
  w.writeInt(dialogData.length);
  for (const { peerKey, topMessage } of dialogData) {
    const isSavedMessages = peerKey === `user:${selfId}`;
    const fixtureMsg: FixtureMessage = {
      id: topMessage.messageId,
      peerKey: topMessage.peerKey,
      date: topMessage.date,
      text: topMessage.text,
      className: 'Message',
      out: isSavedMessages ? false : topMessage.isOutgoing,
      post: topMessage.post,
      fromPeerKey: isSavedMessages ? undefined : topMessage.fromPeerKey,
      savedPeerKey: isSavedMessages ? `user:${selfId}` : undefined,
    };
    writeMessageFromFixture(w, fixtureMsg);
  }

  // chats: empty Vector<Chat>
  w.writeInt(0x1cb5c415);
  w.writeInt(0);

  // users: Vector<User>
  const userIds = Array.from(userIdSet);
  w.writeInt(0x1cb5c415);
  w.writeInt(userIds.length);
  for (const userId of userIds) {
    const isSelf = userId === String(selfId);
    writeUserFromFixture(w, getFixtureUserForId(undefined, userId, isSelf));
  }

  return w.getBytes();
}

function parsePeerDialogsRequest(data: Buffer): string[] {
  try {
    const reader = new BinaryReader(data);
    reader.readInt(); // constructor id
    const vectorId = reader.readInt() >>> 0;
    if (vectorId !== 0x1cb5c415) return [];
    const count = reader.readInt();
    const peerKeys: string[] = [];
    for (let i = 0; i < count; i++) {
      const inputDialogPeerCtor = reader.readInt() >>> 0;
      if (inputDialogPeerCtor === 0xfcaafeb7) { // inputDialogPeer
        const key = readInputPeerKey(reader);
        if (key) peerKeys.push(key);
      } else if (inputDialogPeerCtor === 0x64600527) { // inputDialogPeerFolder
        reader.readInt(); // folder_id
      }
    }
    return peerKeys;
  } catch (e) {
    console.error('Failed to parse getPeerDialogs request:', (e as Error).message);
    return [];
  }
}

function buildPeerDialogsForPeers(peerKeys: string[], selfId: number): Buffer {
  const w = new BinaryWriter();
  // messages.peerDialogs#3371c354 dialogs:Vector<Dialog> messages:Vector<Message>
  // chats:Vector<Chat> users:Vector<User> state:updates.State
  w.writeInt(0x3371c354);

  const userIdSet = new Set<string>([String(selfId)]);

  // dialogs: Vector<Dialog>
  w.writeInt(0x1cb5c415);
  w.writeInt(peerKeys.length);
  for (const peerKey of peerKeys) {
    const lastMsg = messageStore.getLastMessageForUser(peerKey, selfId);
    const peerState = messageStore.getPeerState(selfId, peerKey);
    // dialog#d58a08c6
    w.writeInt(0xd58a08c6);
    w.writeInt(0); // flags
    writePeerByKey(w, peerKey);
    w.writeInt(lastMsg?.messageId || 0); // top_message
    w.writeInt(peerState?.readInboxMaxId || 0); // read_inbox_max_id
    w.writeInt(peerState?.readOutboxMaxId || 0); // read_outbox_max_id
    const peerUnread = messageStore.getUnreadCount(selfId, peerKey);
    w.writeInt(peerUnread); // unread_count
    w.writeInt(0); // unread_mentions_count
    w.writeInt(0); // unread_reactions_count
    writePeerNotifySettingsToWriter(w);
    // Collect user IDs
    if (peerKey.startsWith('user:')) {
      userIdSet.add(peerKey.replace('user:', ''));
    }
  }

  // messages: Vector<Message> — include top messages if any
  const topMessages: FixtureMessage[] = [];
  for (const peerKey of peerKeys) {
    const lastMsg = messageStore.getLastMessageForUser(peerKey, selfId);
    if (lastMsg) {
      const isSavedMessages = peerKey === `user:${selfId}`;
      topMessages.push({
        id: lastMsg.messageId,
        peerKey: lastMsg.peerKey,
        date: lastMsg.date,
        text: lastMsg.text,
        className: 'Message',
        out: isSavedMessages ? false : lastMsg.isOutgoing,
        post: lastMsg.post,
        fromPeerKey: isSavedMessages ? undefined : lastMsg.fromPeerKey,
        savedPeerKey: isSavedMessages ? `user:${selfId}` : undefined,
      });
    }
  }
  w.writeInt(0x1cb5c415);
  w.writeInt(topMessages.length);
  for (const msg of topMessages) {
    writeMessageFromFixture(w, msg);
  }

  // chats: empty
  w.writeInt(0x1cb5c415);
  w.writeInt(0);

  // users: Vector<User>
  const userIds = Array.from(userIdSet);
  w.writeInt(0x1cb5c415);
  w.writeInt(userIds.length);
  for (const userId of userIds) {
    const isSelf = userId === String(selfId);
    writeUserFromFixture(w, getFixtureUserForId(undefined, userId, isSelf));
  }

  // state: updates.state
  writeUpdatesStateToWriter(w);
  return w.getBytes();
}

function buildPeerDialogs(): Buffer {
  return buildPeerDialogsForPeers([], 0);
}

function buildNearestDc(): Buffer {
  const w = new BinaryWriter();
  // nearestDc#8e1a1775 country:string this_dc:int nearest_dc:int
  w.writeInt(0x8e1a1775);
  writeTlString(w, 'US');
  w.writeInt(2);  // this_dc
  w.writeInt(2);  // nearest_dc
  return w.getBytes();
}

function buildBoolTrue(): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0x997275b5);  // boolTrue
  return w.getBytes();
}

function buildBoolFalse(): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0xbc799737);  // boolFalse
  return w.getBytes();
}

// ========== AUTH BUILDERS ==========

function buildSentCode(phoneCodeHash: string, codeLength: number): Buffer {
  const w = new BinaryWriter();
  // auth.sentCode#5e002502 flags:# type:auth.SentCodeType phone_code_hash:string next_type:flags.1?auth.CodeType timeout:flags.2?int
  const flags = (1 << 2); // timeout present
  w.writeInt(0x5e002502);
  w.writeInt(flags);
  // type: auth.sentCodeTypeApp#3dbb5986 length:int
  w.writeInt(0x3dbb5986);
  w.writeInt(codeLength);
  writeTlString(w, phoneCodeHash);
  // next_type: flags.1 — NOT present
  // timeout: flags.2 — present
  w.writeInt(300); // 5 minutes
  return w.getBytes();
}

function buildAuthAuthorization(user: import('../database/messageStore.js').StoredUser): Buffer {
  const w = new BinaryWriter();
  // auth.authorization#2ea2c0d4 flags:# setup_password_required:flags.1?true otherwise_relogin_days:flags.1?int tmp_sessions:flags.0?int future_auth_token:flags.2?bytes user:User
  w.writeInt(0x2ea2c0d4);
  w.writeInt(0); // flags — no optional fields
  // Write user TL object
  writeUserFromFixture(w, {
    id: String(user.id),
    accessHash: user.accessHash.toString(),
    firstName: user.firstName,
    phone: user.phone,
    self: true,
  });
  return w.getBytes();
}

function buildAuthSignUpRequired(): Buffer {
  const w = new BinaryWriter();
  // auth.authorizationSignUpRequired#44747e9a flags:# terms_of_service:flags.0?help.TermsOfService
  w.writeInt(0x44747e9a);
  w.writeInt(0); // flags — no terms
  return w.getBytes();
}

function buildContactsEmpty(): Buffer {
  const w = new BinaryWriter();
  // contacts.contacts#eae87e42 contacts:Vector<Contact> saved_count:int users:Vector<User>
  w.writeInt(0xeae87e42);
  // contacts: empty
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  w.writeInt(0);  // saved_count
  // users: empty
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  return w.getBytes();
}

function buildContactsFromDb(selfId: number): Buffer {
  const allUsers = messageStore.getAllUsers(selfId);
  const w = new BinaryWriter();
  // contacts.contacts#eae87e42 contacts:Vector<Contact> saved_count:int users:Vector<User>
  w.writeInt(0xeae87e42);
  // contacts: Vector<Contact>
  w.writeInt(0x1cb5c415);
  w.writeInt(allUsers.length);
  for (const user of allUsers) {
    // contact#145ade0b user_id:long mutual:Bool
    w.writeInt(0x145ade0b);
    w.writeLong(BigInt(user.id));
    w.writeInt(0x997275b5); // boolTrue — mutual
  }
  w.writeInt(allUsers.length); // saved_count
  // users: Vector<User>
  w.writeInt(0x1cb5c415);
  w.writeInt(allUsers.length);
  for (const user of allUsers) {
    writeUserFromFixture(w, {
      id: String(user.id),
      accessHash: user.accessHash.toString(),
      firstName: user.firstName,
      lastName: user.lastName,
      phone: user.phone,
    });
  }
  return w.getBytes();
}

function buildContactsFound(query: string, selfId: number): Buffer {
  const foundUsers = messageStore.searchUsers(query, selfId);
  const w = new BinaryWriter();
  // contacts.found#b3134d9d myResults:Vector<Peer> results:Vector<Peer> chats:Vector<Chat> users:Vector<User>
  w.writeInt(0xb3134d9d);
  // myResults: empty
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  // results: Vector<Peer>
  w.writeInt(0x1cb5c415);
  w.writeInt(foundUsers.length);
  for (const user of foundUsers) {
    // peerUser#59511722 user_id:long
    w.writeInt(0x59511722);
    w.writeLong(BigInt(user.id));
  }
  // chats: empty
  w.writeInt(0x1cb5c415);
  w.writeInt(0);
  // users: Vector<User>
  w.writeInt(0x1cb5c415);
  w.writeInt(foundUsers.length);
  for (const user of foundUsers) {
    writeUserFromFixture(w, {
      id: String(user.id),
      accessHash: user.accessHash.toString(),
      firstName: user.firstName,
      lastName: user.lastName,
      phone: user.phone,
    });
  }
  return w.getBytes();
}

// contacts.resolvedPeer#7f077ad9 peer:Peer chats:Vector<Chat> users:Vector<User>
function buildResolvedPeer(username: string): Buffer {
  const user = messageStore.getUserByUsername(username);
  if (!user) {
    return buildRpcErrorObject(400, 'USERNAME_NOT_OCCUPIED');
  }
  return buildResolvedPeerForUser(user);
}

function buildResolvedPeerForUser(user: StoredUser): Buffer {
  const w = new BinaryWriter();
  w.writeInt(0x7f077ad9); // contacts.resolvedPeer
  // peer: PeerUser#59511722
  w.writeInt(0x59511722);
  w.writeLong(BigInt(user.id));
  // chats: empty vector
  writeEmptyVectorToWriter(w);
  // users: Vector<User> with 1 user
  w.writeInt(0x1cb5c415);
  w.writeInt(1);
  writeUserFromFixture(w, {
    id: String(user.id),
    accessHash: user.accessHash.toString(),
    firstName: user.firstName,
    lastName: user.lastName || undefined,
    username: user.username,
    phone: user.phone,
  });
  return w.getBytes();
}

function parseForwardMessagesRequest(data: Buffer, session: ClientSession): { fromPeerKey: string | undefined; toPeerKey: string | undefined; messageIds: number[]; randomIds: string[] } | undefined {
  try {
    const reader = new BinaryReader(data);
    reader.offset = 4; // skip constructor
    const flags = reader.readInt() >>> 0;

    // from_peer: InputPeer
    const fromPeerKey = readInputPeerKey(reader);

    // id: Vector<int>
    const vectorCid = reader.readInt() >>> 0;
    const idCount = reader.readInt();
    const messageIds: number[] = [];
    for (let i = 0; i < idCount; i++) {
      messageIds.push(reader.readInt());
    }

    // random_id: Vector<long>
    const rVectorCid = reader.readInt() >>> 0;
    const rCount = reader.readInt();
    const randomIds: string[] = [];
    for (let i = 0; i < rCount; i++) {
      randomIds.push(reader.readLong(false).toString());
    }

    // to_peer: InputPeer
    const toPeerKey = readInputPeerKey(reader);

    return { fromPeerKey, toPeerKey, messageIds, randomIds };
  } catch (e) {
    console.log(`[WARN] parseForwardMessagesRequest: parse error:`, (e as Error).message);
    return undefined;
  }
}

