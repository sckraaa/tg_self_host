function buildAccountPassword(): Buffer {
  const w = new BinaryWriter();
  // account.password#957b50fb flags:# has_recovery:flags.0?true has_secure_values:flags.1?true
  // has_password:flags.2?true current_algo:flags.2?PasswordKdfAlgo
  // srp_B:flags.2?bytes srp_id:flags.2?long
  // hint:flags.3?string email_unconfirmed_pattern:flags.4?string
  // new_algo:PasswordKdfAlgo new_secure_algo:SecurePasswordKdfAlgo secret_random:bytes
  // pending_reset_date:flags.5?int login_email_pattern:flags.6?string
  w.writeInt(0x957b50fb);
  w.writeInt(0);  // flags (has_password=false)
  // current_algo: flags.2 — NOT present
  // srp_B: flags.2 — NOT present
  // srp_id: flags.2 — NOT present
  // hint: flags.3 — NOT present
  // email_unconfirmed_pattern: flags.4 — NOT present
  // new_algo: passwordKdfAlgoUnknown#d45ab096
  w.writeInt(0xd45ab096);
  // new_secure_algo: securePasswordKdfAlgoUnknown#4a8537
  w.writeInt(0x004a8537);
  // secure_random: bytes (empty)
  writeTlBytes(w, Buffer.alloc(0));
  return w.getBytes();
}

