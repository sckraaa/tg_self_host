    case 0x6628562c: { // account.updateStatus
      console.log(`[${new Date().toISOString()}] Session ${session.id} account.updateStatus`);
      const statusSelfId = session.userId || SEED_USER_ID;
      // Parse offline flag: account.updateStatus#6628562c offline:Bool
      const statusReader = new BinaryReader(data);
      statusReader.readInt(); // constructor
      const offlineCtor = statusReader.readInt() >>> 0;
      const isOffline = offlineCtor === 0xbc799737; // boolTrue = offline
      // Broadcast status to all contacts
      const statusUpdate = buildUpdateUserStatus(statusSelfId, isOffline);
      const allUsers = messageStore.getAllUsers();
      for (const user of allUsers) {
        if (user.id !== statusSelfId) {
          broadcastToUser(user.id, statusUpdate);
        }
      }
      return buildBoolTrue();
    }

