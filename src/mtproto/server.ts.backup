function buildChannelFullFromFixture(fixture: OfficialCaptureFixture, channelId: string): Buffer {
  const chat = fixture.chatsById[channelId];
  if (!chat) {
    return buildChannelFullEmpty(channelId);
  }

  const peerKey = `channel:${channelId}`;
  const fixtureDialog = fixture.dialogs.find((dialog) => dialog.peerKey === peerKey);
  const readState = getReadStateForPeerKey(peerKey, SEED_USER_ID, fixtureDialog);
  const channelPts = fixture.historiesByKey[peerKey]?.pts || messageStore.getUpdateState().pts;

  const w = new BinaryWriter();
  // messages.chatFull#e5d7d19c full_chat:ChatFull chats:Vector<Chat> users:Vector<User>
  w.writeInt(0xe5d7d19c);

  // channelFull#e4e0b29d
  w.writeInt(0xe4e0b29d);
  w.writeInt(0); // flags
  w.writeInt(0); // flags2
  w.writeLong(BigInt(channelId));
  writeTlString(w, '');
  w.writeInt(readState.readInboxMaxId);
  w.writeInt(readState.readOutboxMaxId);
  w.writeInt(0); // unread_count
  writePhotoEmpty(w, 0n);
  writePeerNotifySettingsToWriter(w);
  writeEmptyVectorToWriter(w); // bot_info
  w.writeInt(channelPts);

  w.writeInt(0x1cb5c415);
  w.writeInt(1);
  writeChatFromFixture(w, chat);

  writeEmptyVectorToWriter(w); // users
  return w.getBytes();
}

