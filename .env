# ═══════════════════════════════════════════════════════════
#  REQUIRED — must be set before running setup.sh
# ═══════════════════════════════════════════════════════════

# Your VPS domain (e.g. pluma.chat)
DOMAIN=pluma.chat

# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890

# ═══════════════════════════════════════════════════════════
#  OPTIONAL — reasonable defaults provided
# ═══════════════════════════════════════════════════════════

# App branding
APP_NAME=pluma

# STUN/TURN (coturn) credentials
# These are used BOTH by docker-compose (to start coturn)
# AND by the backend (passed to Telegram clients as ICE servers)
COTURN_PORT=3478
COTURN_USER=pluma
COTURN_PASS=FCBarcelona2k!9100
